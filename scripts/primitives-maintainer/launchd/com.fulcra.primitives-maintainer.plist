<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.fulcra.primitives-maintainer</string>
    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>__CHECKOUT__/scripts/primitives-maintainer/drift-check.sh</string>
    </array>
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>9</integer>
        <key>Minute</key>
        <integer>13</integer>
    </dict>
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/Users/Scanning/.local/bin:/opt/homebrew/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
    </dict>
    <key>StandardOutPath</key>
    <string>__CHECKOUT__/.primitives-state/launchd.out.log</string>
    <key>StandardErrorPath</key>
    <string>__CHECKOUT__/.primitives-state/launchd.err.log</string>
</dict>
</plist>
