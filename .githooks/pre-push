#!/usr/bin/env bash
#
# fulcra-tools pre-push hook — run the fulcra-coord test suite before any push
# that changes fulcra-coord, so a red suite is caught LOCALLY instead of after
# merge. This is the always-on gate (GitHub Actions macOS CI is path-filtered to
# macOS-specific changes only, so a pure fulcra-coord change otherwise has no
# automated test gate).
#
# ENABLE ONCE PER CLONE (the hook lives in version control, but core.hooksPath
# is per-clone config and not auto-applied):
#     git config core.hooksPath .githooks
#
# BYPASS A SINGLE PUSH (e.g. docs-only WIP branch you'll fix up):
#     git push --no-verify
#
# Requires `uv` on PATH. Only runs when the pushed commits touch
# packages/fulcra-coord/ — other pushes (docs, chrome ext, other packages) skip.
#
set -uo pipefail

repo_root="$(git rev-parse --show-toplevel)"
# Only the package's code, tests, and dependency manifest gate the push — a
# README/docs/CHANGELOG-only change under packages/fulcra-coord/ skips the suite.
COORD_RELEVANT='^packages/fulcra-coord/(fulcra_coord/|tests/|pyproject\.toml)'
ZERO="0000000000000000000000000000000000000000"

# pre-push passes "<local_ref> <local_sha> <remote_ref> <remote_sha>" lines on
# stdin. Collect the files changed across every ref being pushed.
changed=""
while read -r local_ref local_sha remote_ref remote_sha; do
  [ -z "${local_sha:-}" ] && continue
  [ "$local_sha" = "$ZERO" ] && continue            # branch deletion: nothing to test
  if [ "${remote_sha:-$ZERO}" = "$ZERO" ]; then     # new branch on the remote
    base="$(git merge-base origin/main "$local_sha" 2>/dev/null || true)"
  else
    base="$remote_sha"
  fi
  if [ -n "$base" ]; then
    range="$base..$local_sha"
  else
    range="$local_sha"                              # no base found: inspect the tip commit
  fi
  changed+="$(git diff --name-only "$range" 2>/dev/null)"$'\n'
done

# Fallback when nothing arrived on stdin (e.g. invoked manually): HEAD vs origin/main.
if [ -z "${changed//[[:space:]]/}" ]; then
  changed="$(git diff --name-only origin/main...HEAD 2>/dev/null)"
fi

if ! printf '%s\n' "$changed" | grep -qE "$COORD_RELEVANT"; then
  exit 0   # no fulcra-coord code/test/dep changes -> skip
fi

echo "pre-push: fulcra-coord changed — running its test suite (bypass: git push --no-verify)"
cd "$repo_root/packages/fulcra-coord" || exit 0
if uv run --extra dev python -m pytest -q; then
  echo "pre-push: fulcra-coord suite green"
  exit 0
fi

echo ""
echo "pre-push: fulcra-coord tests FAILED — push blocked."
echo "         Fix the suite, or override this one push with: git push --no-verify"
exit 1
