# Set these on Railway (Project → Variables). NOT in this file.
# .env here is gitignored; just a checklist.

# The real OpenRouter key the proxy translates virtual keys into. Use a capped
# key tied to your fulcra-dynamics OpenRouter account.
OPENROUTER_API_KEY=sk-or-v1-...

# Pick any long random string. Operator-only (used by spawn.js to mint virtual
# keys). NEVER injected into sandboxes.
LITELLM_MASTER_KEY=sk-litellm-...

# DATABASE_URL is auto-set by Railway's managed Postgres add-on once attached.
# Don't set manually.
# DATABASE_URL=postgres://...
