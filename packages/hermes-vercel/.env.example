# Copy to .env and fill in. .env is gitignored.

# --- Vercel Sandbox (where guests run) ---
VERCEL_TOKEN=
VERCEL_TEAM_ID=
VERCEL_PROJECT_ID=

# --- Model: either inject a capped OpenRouter key directly into each sandbox
#     (baseline), OR point at the LiteLLM proxy and mint per-sandbox virtual
#     keys (recommended; see docs/ARCHITECTURE.md). ---
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-sonnet-4.5

# --- LiteLLM AI gateway (only set if using the gateway path) ---
# When set, spawn.js mints a per-sandbox virtual key via LiteLLM admin API and
# injects (BASE_URL, virtual key) into the sandbox instead of the raw key.
LITELLM_URL=
LITELLM_MASTER_KEY=
