# Copy to .env and fill in. .env is gitignored — never commit real keys.

# Daytona API key (your account pays for all guest sandboxes).
DAYTONA_API_KEY=dtn_your_key_here

# OpenRouter key — injected into each sandbox so the agent can talk to the model.
# Use a DISPOSABLE, low-credit-cap key for demos and rotate it after (a guest can
# ask the agent to print its own env). See the README security note.
OPENROUTER_API_KEY=sk-or-your_key_here

# Optional: the model the Hermes agent uses (this is the default if unset).
OPENROUTER_MODEL=anthropic/claude-sonnet-4.5
