<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- iOS extension: same App Group + keychain access group as the iOS app. -->
	<key>com.apple.security.application-groups</key>
	<array>
		<string>group.com.fulcra.attention</string>
	</array>
	<key>keychain-access-groups</key>
	<array>
		<string>$(AppIdentifierPrefix)com.fulcra.attention.shared</string>
	</array>
</dict>
</plist>
