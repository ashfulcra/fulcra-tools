{
  "manifest_version": 3,
  "name": "Fulcra Attention",
  "version": "0.1.0",
  "description": "Capture browsing attention into your Fulcra account.",
  "permissions": [
    "webNavigation",
    "tabs",
    "storage",
    "alarms",
    "activeTab",
    "contextMenus",
    "identity",
    "scripting",
    "idle",
    "history",
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "http://127.0.0.1:9292/*",
    "https://api.fulcradynamics.com/*",
    "https://fulcra.us.auth0.com/*"
  ],
  "optional_host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "src/background.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["http://127.0.0.1:*/*", "http://localhost:*/*"],
      "js": ["src/pair-listener.ts"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16":  "icons/icon-active-16.png",
    "32":  "icons/icon-active-32.png",
    "48":  "icons/icon-active-48.png",
    "128": "icons/icon-active-128.png"
  },
  "action": {
    "default_popup": "index.html",
    "default_title": "Fulcra Attention",
    "default_icon": {
      "16": "icons/icon-active-16.png",
      "32": "icons/icon-active-32.png",
      "48": "icons/icon-active-48.png",
      "128": "icons/icon-active-128.png"
    }
  },
  "options_page": "options.html",
  "web_accessible_resources": [
    {
      "resources": [
        "icons/icon-active-16.png", "icons/icon-active-32.png",
        "icons/icon-active-48.png", "icons/icon-active-128.png",
        "icons/icon-paused-16.png", "icons/icon-paused-32.png",
        "icons/icon-paused-48.png", "icons/icon-paused-128.png",
        "icons/icon-error-16.png",  "icons/icon-error-32.png",
        "icons/icon-error-48.png",  "icons/icon-error-128.png"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
