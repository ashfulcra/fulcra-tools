{
  "name": "@fulcra/openclaw-coord",
  "version": "0.1.0",
  "description": "Fulcra coordination plugin for OpenClaw — deterministic per-session and before-compaction checkpoints to the fulcra-coord bus.",
  "type": "module",
  "main": "./dist/index.js",
  "files": [
    "dist",
    "src",
    ".npmrc",
    "openclaw.plugin.json",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json"
  },
  "openclaw": {
    "extensions": ["./dist/index.js"],
    "compat": {
      "pluginApi": ">=2026.5.28",
      "minGatewayVersion": "2026.5.28"
    }
  },
  "peerDependencies": {
    "openclaw": ">=2026.5.28"
  },
  "devDependencies": {
    "@types/node": "^22",
    "typescript": "^5.4.0"
  }
}
